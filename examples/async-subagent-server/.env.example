ANTHROPIC_API_KEY=
TAVILY_API_KEY=   # optional — stub search used if not set
PORT=2024         # port the server listens on (default: 2024)
RESEARCHER_URL=   # supervisor only — defaults to http://localhost:2024

# Postgres connection string (required when running server.ts)
# docker-compose sets this automatically; set it manually for local dev
DATABASE_URL=postgres://postgres:postgres@localhost:5433/agentdb
